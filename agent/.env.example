# Copy to agent/.env and fill in. Headless hermetic tests need NONE of these.

# --- LiveKit Cloud (worker / `python agent.py console`) ---
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_PROJECT_ID=

# --- STT (swappable model id) ---
STT_MODEL=deepgram/nova-3
STT_LANGUAGE=multi

# --- TTS: minimax | inference  (minimax may need MINIMAX_GROUP_ID; else falls back) ---
TTS_PROVIDER=minimax
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE=English_expressive_narrator
# TTS host WITHOUT /v1 (plugin appends /v1/t2a_v2; do NOT reuse MINIMAX_BASE_URL here)
MINIMAX_TTS_BASE_URL=https://api.minimax.io
MINIMAX_GROUP_ID=
INFERENCE_TTS_MODEL=cartesia/sonic-2

# --- Minimax (TTS + Tier-2 LLM) ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_LLM_MODEL=MiniMax-M3

# --- Tier-2 retrieval tuning ---
TIER2_ALPHA=0.6
TIER2_TOP_K=4

# --- Retrieval backend: fake (default) | moss (not wired yet) ---
RETRIEVAL_BACKEND=fake
MOSS_INDEX_NAME=vigil_protocols
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=

# --- Testing: set to 1 to enable opt-in integration tests that hit real services ---
RUN_INTEGRATION=
